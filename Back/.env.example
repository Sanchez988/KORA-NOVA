# Configuración del Servidor
NODE_ENV=development
PORT=5000
# Escucha en todas las interfaces para que Expo Go / móvil en la misma Wi‑Fi llegue por IP LAN.
# Solo en casos excepcionales: HOST=127.0.0.1
HOST=0.0.0.0
# URL pública del API (enlaces en correos, /uploads, Swagger). En el móvil «localhost» rompe imágenes/audio.
# En LAN: misma IP/host que uses en el teléfono, p. ej. http://192.168.1.4:5000
# En Render: si no defines API_URL, el backend usa RENDER_EXTERNAL_URL (https://tu-servicio.onrender.com).
# Sin Cloudinary en prod, NO uses solo disco local: el dyno borra archivos al reiniciar.
API_URL=http://localhost:5000

# Verificación de correo al registrar:
# true  -> exige código por email antes de iniciar sesión
# false -> auto-verifica (útil para pruebas sin SMTP)
EMAIL_VERIFICATION_REQUIRED=false

# Si true (por defecto en código: true), registro y reenvío incluyen el código en el JSON de la API
# además del correo SMTP. La app lo muestra cuando el buzón institucional bloquea o falla la entrega.
# Pon false solo si confías 100% en SMTP y no quieres el código en la respuesta HTTPS.
# EMAIL_VERIFICATION_INCLUDE_CODE_IN_RESPONSE=true

# Base de Datos (PostgreSQL obligatorio)
#
# A) Postgres solo para este repo (docker-compose.yml en la raíz: usuario kora / base kora_db):
# DATABASE_URL="postgresql://kora:kora@localhost:5432/kora_db?schema=public"
#
# B) Mismo Postgres que kora-fix/infrastructure (defaults en su .env: kora_user / kora_password).
#    Crear BD dedicada para Prisma (sin mezclar tablas Django):
#    docker exec infrastructure-db-1 psql -U kora_user -d postgres -c "CREATE DATABASE kora_mobile_entrega OWNER kora_user;"
DATABASE_URL="postgresql://kora_user:kora_password@localhost:5432/kora_mobile_entrega?schema=public"

# JWT Secrets
JWT_SECRET=tu_clave_secreta_super_segura_cambiala_en_produccion_min_32_caracteres
JWT_REFRESH_SECRET=tu_clave_refresh_secreta_super_segura_cambiala_en_produccion_min_32_caracteres
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration (Nodemailer) — obligatorio para que lleguen correos reales
# (registro, verificación, recuperación de contraseña). Si EMAIL_USER o EMAIL_PASSWORD
# están vacíos, el servidor NO envía nada (solo registra en logs).
#
# Gmail: crea una "Contraseña de aplicación" en tu cuenta Google (no uses la clave normal).
# Correo institucional: usa el SMTP que te indique el campus si bloquea Gmail.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@pascualbravo.edu.co
EMAIL_PASSWORD=tu_contraseña_de_app
EMAIL_FROM=Kora <noreply@kora.app>

# Recuperación de contraseña: si es true, la API siempre incluye devResetCode (solo pruebas controladas).
# Si está en false y el correo NO se puede enviar (sin EMAIL_* o fallo SMTP), el código igual se devuelve
# en la respuesta JSON (in_app) para poder restablecer sin depender del buzón.
PASSWORD_RESET_DEV_CODE_IN_RESPONSE=false

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Cloudinary (para almacenar imágenes)
# Opción A (recomendada): URL única
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
#
# Opción B: variables separadas
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Configuración de Seguridad
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_TIME=900000

# Google OAuth (mismo proyecto que el Front: cliente tipo «Aplicación web»).
# CLIENT_ID público también en Front; CLIENT_SECRET sólo aquí en el servidor.
# Obligatorio si el login con Google desde Expo Go canjea código en el backend (/auth/google/oauth-code).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:5173
